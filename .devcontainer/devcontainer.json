// For format details, see https://aka.ms/devcontainer.json.
{
  "name": "nix-utils",

  "build": {
    "dockerfile": "Dockerfile"
  },

  "features": {
    "ghcr.io/devcontainers/features/common-utils:2": {
      "configureZshAsDefaultShell": true
    },
    "ghcr.io/devcontainers/features/github-cli:1": {}
  },

  // Determinate's `--init none` install does not manage the daemon, and this
  // image has no systemd, so start nix-daemon ourselves once the container is
  // up. The non-root `vscode` user talks to it over the daemon socket.
  "postStartCommand": "sudo sh -c 'pgrep -x nix-daemon >/dev/null 2>&1 || (nix-daemon >/tmp/nix-daemon.log 2>&1 &)'",

  "customizations": {
    "vscode": {
      "extensions": [
        "editorconfig.editorconfig",
        "redhat.vscode-yaml",
        "jnoortheen.nix-ide",
        "github.vscode-github-actions",
        "github.vscode-pull-request-github"
      ]
    }
  }
}
